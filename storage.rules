rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /products/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid &&
        request.resource.size < 150 * 1024 * 1024 &&
        (request.resource.contentType.matches('image/(jpeg|png|webp|gif)') ||
         request.resource.contentType.matches('video/(mp4|webm|quicktime)'));
    }

    match /ads/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        request.resource.size < 20 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    match /adminChatFiles/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() &&
        request.resource.size < 20 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
